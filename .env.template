# ==========================================================
# Jubu Cloud — Environment Variables
# Copy to .env and fill in real values
# ==========================================================

# ── API Keys ──
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...
OPENAI_ORGANIZATION=org-...
ASSEMBLY_API_KEY=...
ELEVENLABS_API_KEY=...

# ── Google Cloud Credentials ──
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/service-account.json

# ── Database ──
POSTGRES_PASSWORD=CHANGE_ME

# ── LiveKit ──
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devkey-secret-at-least-32-characters!!
LIVEKIT_ROOM=jubu-demo
LIVEKIT_IDENTITY=buju-ai

# ── Server ──
PUBLIC_IP=0.0.0.0

# ── Auth ──
SECRET_KEY=CHANGE_ME

# ── Demo Mode ──
DEMO_MODE=1
DEMO_CHILD_ID=...
DEMO_PARENT_ID=...

# ── Voice Tuning ──
# Per-frontend tuning lives in jubu_backend/voice_profiles/{default,pi,phone}.yaml.
# Env vars below act as GLOBAL OVERRIDES that win over both YAML profiles —
# useful as an operational escape hatch (e.g. tighten barge-in for everyone
# in an incident without redeploying).  Leave them unset to use YAML values.
GEMINI_MAX_CONCURRENCY=5
# VAD_AGGRESSIVENESS=2
# BARGE_IN_SPEECH_MS=500
# BARGE_IN_MIN_RMS=350
# BARGE_IN_COOLDOWN_MS=1500
# ELEVENLABS_SPEED=0.93
# ELEVENLABS_STABILITY=0.60
# ELEVENLABS_INTER_SENTENCE_GAP_MS=60

# ── GitHub (for Docker build — cloning private repos) ──
# Generate at: https://github.com/settings/tokens (select 'repo' scope)
GITHUB_TOKEN=ghp_...

# ── Branch Control (optional, defaults to 'main') ──
# BACKEND_BRANCH=main
# PARENT_APP_BRANCH=main
# DATASTORE_BRANCH=main
