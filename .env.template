# ==========================================================
# Jubu Cloud — Environment Variables
# Copy to .env and fill in real values
# ==========================================================

# ── API Keys ──
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...
OPENAI_ORGANIZATION=org-...
ASSEMBLY_API_KEY=...
ELEVENLABS_API_KEY=...

# ── Google Cloud Credentials ──
# Path inside containers (mounted via docker-compose volume)
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/service-account.json

# ── Database ──
POSTGRES_PASSWORD=CHANGE_ME_generate_a_strong_password_here

# ── LiveKit ──
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devkey-secret-at-least-32-characters!!
LIVEKIT_ROOM=jubu-demo
LIVEKIT_IDENTITY=jubu-bot

# ── Server ──
# Your GCP VM's public IP (needed for LiveKit ICE candidates)
# Find it: gcloud compute instances describe jubu-server --format='get(networkInterfaces[0].accessConfigs[0].natIP)'
PUBLIC_IP=0.0.0.0

# ── Demo Mode ──
DEMO_MODE=1
DEMO_CHILD_ID=...
DEMO_PARENT_ID=...

# ── Voice Tuning ──
GEMINI_MAX_CONCURRENCY=5
VAD_AGGRESSIVENESS=2
BARGE_IN_SPEECH_MS=500
BARGE_IN_MIN_RMS=350
BARGE_IN_COOLDOWN_MS=1500
ELEVENLABS_SPEED=0.93
ELEVENLABS_STABILITY=0.60
ELEVENLABS_INTER_SENTENCE_GAP_MS=60

# ── GitHub Token (for private repos in Docker build) ──
# Only needed if jubu_datastore is private
# Generate at: https://github.com/settings/tokens (repo scope)
GITHUB_TOKEN=
