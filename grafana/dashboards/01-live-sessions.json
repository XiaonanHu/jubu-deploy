      "fieldConfig": {"defaults": {"custom": {"drawStyle": "bars", "fillOpacity": 50}, "unit": "short"}, "overrides": []},
      "options": {"legend": {"showLegend": false}, "tooltip": {"mode": "single"}},
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT date_trunc('hour', start_time) AS time, COUNT(*) AS sessions FROM conversations WHERE start_time > NOW() - INTERVAL '7 days' GROUP BY 1 ORDER BY 1",
          "datasource": {"type": "postgres", "uid": "buju-postgres"}
        }
