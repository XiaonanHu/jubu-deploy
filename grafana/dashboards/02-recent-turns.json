        "overrides": [
          {"matcher": {"id": "byName", "options": "child"}, "properties": [{"id": "custom.width", "value": 320}]},
          {"matcher": {"id": "byName", "options": "buju"}, "properties": [{"id": "custom.width", "value": 420}]},
          {"matcher": {"id": "byName", "options": "redacted"}, "properties": [{"id": "custom.cellOptions", "value": {"type": "color-text"}}, {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"value": null, "color": "transparent"}, {"value": 1, "color": "red"}]}}]},
