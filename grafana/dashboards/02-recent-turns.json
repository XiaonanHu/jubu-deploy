      },
      "options": {"showHeader": true, "footer": {"show": false}},
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT t.timestamp AS ts, t.conversation_id, p.name AS who, LEFT(COALESCE(t.child_message, ''), 80) AS child, LEFT(COALESCE(t.system_message, ''), 80) AS buju, CASE WHEN t.safety_evaluation->>'redact_turn' = 'true' THEN 1 ELSE 0 END AS redacted FROM conversation_turns t LEFT JOIN conversations c ON c.id = t.conversation_id LEFT JOIN child_profiles p ON p.id = c.child_id WHERE (${conversation_id:singlequote} = 'all' OR t.conversation_id = ${conversation_id:singlequote}) ORDER BY t.timestamp DESC LIMIT 200",
          "datasource": {"type": "postgres", "uid": "buju-postgres"}
        }
      ]
