# Basic-auth file for stats.buju.ai (Phase 0).  REAL htpasswd lives at
# nginx/htpasswd (gitignored).  Generate it on the server with:
#
#     htpasswd -B -c nginx/htpasswd admin
#     # enter password when prompted, then commit ONLY this .example file
#
# Add more users with `htpasswd -B nginx/htpasswd <user>` (no -c — that
# overwrites).
#
# Phase 3 swaps this for parent-api SSO via nginx auth_request, after
# which this file becomes obsolete.
admin:$2y$05$EXAMPLE_PLACEHOLDER_NOT_A_REAL_HASH_REPLACE_ME_PLEASE
